# 백엔드 API (팀 공용 레포 연동 후 팀원별 .env에 설정)
EXPO_PUBLIC_API_URL=https://api.clothingfit.app

# Orval API 코드 생성용 OpenAPI 스펙 URL (npm run generate:api)
OPENAPI_URL=https://clothing-fit-be.onrender.com/openapi.json

# 구글 OAuth 웹 클라이언트 ID (공개 값 — 비밀 아님)
# Google Cloud Console > 사용자 인증 정보 > OAuth 2.0 > 웹 애플리케이션
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
